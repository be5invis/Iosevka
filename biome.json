{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"packages/*/src/**/*.mjs",
			"tools/*/src/**/*.mjs",
			"verdafile.mjs",

			"!packages/font-glyphs/**/*.mjs",
			"!packages/font-otl/**/*.mjs",
			"!packages/font/src/generated/ttfa-ranges.mjs"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 4,
		"lineEnding": "lf",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"arrowParentheses": "asNeeded"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": {
				"noExcessiveCognitiveComplexity": "off"
			},
			"style": {
				"useConst": "error"
			}
		}
	},
	"overrides": [
		{
			"includes": ["scripts/*.mjs", "electron.vite.config.ts"],
			"javascript": {
				"globals": ["process", "__dirname"]
			}
		},
		{
			"includes": [".vscode/**/*.json"],
			"json": {
				"parser": {
					"allowComments": true,
					"allowTrailingCommas": true
				}
			}
		}
	],
	"assist": {
		"actions": {
			"source": {
				"organizeImports": {
					"level": "on",
					"options": {
						"groups": [
							[":NODE:", "react"],
							":BLANK_LINE:",
							[":PACKAGE:", "!@fc-internal/**"],
							":BLANK_LINE:",
							"@fc-internal/**",
							":BLANK_LINE:",
							["@/components/**", "@/hooks/**"],
							":BLANK_LINE:",
							["@/utils/**", "@/lib/**"],
							":BLANK_LINE:",
							"../**",
							":BLANK_LINE:",
							"./**"
						]
					}
				}
			}
		}
	}
}
