### Punctuation symbols
$$include '../../meta/macros.ptl'

import [mix linreg clamp fallback] from "@iosevka/util"

glyph-module

glyph-block Symbol-Punctuation-Amending : do
	glyph-block-import CommonShapes

	create-glyph "caretInsertionPoint" 0x2041 : glyph-proc
		include : ExtLineCenter SB      Descender RightSB [mix Descender 0 2] OperatorStroke
		include : ExtLineCenter RightSB Descender Middle                 0    OperatorStroke
